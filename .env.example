# Deebaj Royal environment variables
# Copy to .env.local and replace placeholder values.

# Site
NEXT_PUBLIC_SITE_URL=https://deebajroyal.com
NEXT_PUBLIC_SITE_NAME="Deebaj Royal"
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# Moyasar
NEXT_PUBLIC_MOYASAR_PUBLISHABLE_KEY=pk_test_REPLACE_ME
MOYASAR_SECRET_KEY=sk_test_REPLACE_ME

# Tabby
NEXT_PUBLIC_TABBY_PUBLIC_KEY=pk_test_REPLACE_ME
TABBY_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_TABBY_MERCHANT_CODE=SAU

# Tamara
TAMARA_API_TOKEN=REPLACE_ME
TAMARA_NOTIFICATION_TOKEN=REPLACE_ME
NEXT_PUBLIC_TAMARA_PUBLIC_KEY=REPLACE_ME

# Firebase client
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE_ME
NEXT_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=REPLACE_ME
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=REPLACE_ME

# Firebase Admin SDK
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=REPLACE_ME

# Analytics and verification
NEXT_PUBLIC_GA_MEASUREMENT_ID=REPLACE_ME
NEXT_PUBLIC_CLARITY_PROJECT_ID=REPLACE_ME
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=REPLACE_ME
NEXT_PUBLIC_BING_SITE_VERIFICATION=REPLACE_ME

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASSWORD=REPLACE_ME
SMTP_FROM_EMAIL=REPLACE_ME
SMTP_FROM_NAME="Deebaj Royal"

# WhatsApp Business
NEXT_PUBLIC_WHATSAPP_NUMBER=REPLACE_ME

# Shipping APIs
ARAMEX_API_KEY=
ARAMEX_ACCOUNT_NUMBER=
SMSA_API_KEY=
SMSA_PASSKEY=
DHL_API_KEY=

# Error tracking and webhooks
NEXT_PUBLIC_SENTRY_DSN=
WEBHOOK_SECRET=REPLACE_ME
